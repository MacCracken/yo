# yo test suite
# Stdlib auto-included via cyrius.cyml

include "src/icmp.cyr"
include "src/cli.cyr"
include "src/ipv4.cyr"
include "src/ipv6.cyr"
include "src/stats.cyr"
include "src/output.cyr"
include "src/platform.cyr"
include "src/dns.cyr"

# Format us into a stack buf, NUL-terminate, return the buf pointer
# so streq can compare against an expected cstring.
fn _us_fmt(us, buf): i64 {
    var n = _output_us_as_ms_to_buf(us, buf);
    store8(buf + n, 0);
    return buf;
}

# Build a synthetic argv pointer-array from up to 8 cstring literals.
# Pass 0 for unused slots; we'll only honor the first `ac` entries.
# Returns a heap ptr that lib/flags.cyr can index as `argv + i*8`.
fn _mk_argv(a0, a1, a2, a3, a4, a5, a6, a7): i64 {
    var av = alloc(8 * 8);
    store64(av + 0,  a0); store64(av + 8,  a1);
    store64(av + 16, a2); store64(av + 24, a3);
    store64(av + 32, a4); store64(av + 40, a5);
    store64(av + 48, a6); store64(av + 56, a7);
    return av;
}

fn main() {
    alloc_init();

    # ----- checksum primitive -----
    test_group("icmp_checksum");

    # RFC 1071 §4.1 worked example: bytes 00 01 f2 03 f4 f5 f6 f7
    # → sum 0x2DDF0 → fold 0xDDF2 → ~ = 0x220D.
    var rfc[8];
    store8(&rfc + 0, 0x00); store8(&rfc + 1, 0x01);
    store8(&rfc + 2, 0xF2); store8(&rfc + 3, 0x03);
    store8(&rfc + 4, 0xF4); store8(&rfc + 5, 0xF5);
    store8(&rfc + 6, 0xF6); store8(&rfc + 7, 0xF7);
    assert_eq(icmp_checksum(&rfc, 8), 0x220D, "RFC 1071 worked example");

    # Empty buffer: sum=0, ~0 (16-bit) = 0xFFFF.
    var empty[8];
    assert_eq(icmp_checksum(&empty, 0), 0xFFFF, "checksum of zero bytes = 0xFFFF");

    # Odd-length: last byte treated as high byte of a padded word.
    # 0x12 alone → sum = 0x1200 → ~ = 0xEDFF.
    var odd[8];
    store8(&odd, 0x12);
    assert_eq(icmp_checksum(&odd, 1), 0xEDFF, "odd-length padding");

    # ----- build_echo_request -----
    test_group("icmp_build_echo_request");

    var pkt[64];
    var payload[8];
    store8(&payload + 0, 0x68); store8(&payload + 1, 0x65); # "he"
    store8(&payload + 2, 0x6C); store8(&payload + 3, 0x6C); # "ll"
    store8(&payload + 4, 0x6F);                              # "o"
    var n = icmp_build_echo_request(&pkt, 0x1234, 42, &payload, 5);
    assert_eq(n, 13, "header(8) + payload(5) = 13 bytes");

    # Field placement: type=8, code=0, ident=0x1234, seq=42, all big-endian.
    assert_eq(icmp_type(&pkt),  8,      "type = ECHO_REQUEST");
    assert_eq(icmp_code(&pkt),  0,      "code = 0");
    assert_eq(icmp_ident(&pkt), 0x1234, "ident round-trips");
    assert_eq(icmp_seq(&pkt),   42,     "seq round-trips");
    assert_eq(load8(&pkt + 4),  0x12,   "ident high byte at off 4");
    assert_eq(load8(&pkt + 5),  0x34,   "ident low byte at off 5");

    # ----- verify -----
    test_group("icmp_verify");

    assert_eq(icmp_verify(&pkt, 13), 1, "freshly built packet verifies");

    # Header-only (empty payload) also verifies.
    var hdronly[16];
    var nh = icmp_build_echo_request(&hdronly, 1, 1, &payload, 0);
    assert_eq(nh, 8, "header-only packet = 8 bytes");
    assert_eq(icmp_verify(&hdronly, 8), 1, "header-only verifies");

    # Tamper a payload byte → checksum no longer matches.
    store8(&pkt + 10, load8(&pkt + 10) ^ 0xFF);
    assert_eq(icmp_verify(&pkt, 13), 0, "tampered packet fails verify");

    # Too-short buffer → reject without reading past end.
    assert_eq(icmp_verify(&pkt, 4), 0, "len<8 rejected");

    # ----- ICMPv6 build_echo_request -----
    test_group("icmp6_build_echo_request");

    var pkt6[64];
    var n6 = icmp6_build_echo_request(&pkt6, 0xCAFE, 7, &payload, 5);
    assert_eq(n6, 13, "v6 header(8) + payload(5) = 13 bytes");
    assert_eq(load8(&pkt6 + 0), 128,   "v6 type = ECHO_REQUEST (128)");
    assert_eq(load8(&pkt6 + 1), 0,     "v6 code = 0");
    assert_eq(load8(&pkt6 + 2), 0,     "v6 checksum hi = 0 (kernel fills)");
    assert_eq(load8(&pkt6 + 3), 0,     "v6 checksum lo = 0 (kernel fills)");
    assert_eq(load8(&pkt6 + 4), 0xCA,  "v6 ident high byte");
    assert_eq(load8(&pkt6 + 5), 0xFE,  "v6 ident low byte");
    assert_eq(load8(&pkt6 + 6), 0,     "v6 seq high byte");
    assert_eq(load8(&pkt6 + 7), 7,     "v6 seq low byte");
    assert_eq(load8(&pkt6 + 8), 0x68,  "v6 payload byte 0 = 'h'");
    assert_eq(load8(&pkt6 + 12), 0x6F, "v6 payload byte 4 = 'o'");

    # Header-only echo-request also valid
    var hdronly6[16];
    var nh6 = icmp6_build_echo_request(&hdronly6, 1, 1, &payload, 0);
    assert_eq(nh6, 8, "v6 header-only = 8 bytes");
    assert_eq(load8(&hdronly6 + 0), 128, "v6 header-only type = 128");

    # ----- CLI parse: defaults -----
    test_group("cli defaults");

    var reg_d = cli_new();
    var av_d = _mk_argv("yo", "192.168.1.1", 0, 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_d, 2, av_d), CLI_OK, "bare target parses");
    assert_eq(cli_count(reg_d),       YO_DEFAULT_COUNT,       "default count");
    assert_eq(cli_timeout_ms(reg_d),  YO_DEFAULT_TIMEOUT_MS,  "default timeout");
    assert_eq(cli_interval_ms(reg_d), YO_DEFAULT_INTERVAL_MS, "default interval");
    assert_eq(cli_size(reg_d),        YO_DEFAULT_SIZE,        "default size");
    assert_eq(cli_quiet(reg_d),   0, "quiet off by default");
    assert_eq(cli_verbose(reg_d), 0, "verbose off by default");
    assert_eq(streq(cli_target(reg_d), "192.168.1.1"), 1, "target captured");

    # ----- CLI parse: short forms -----
    test_group("cli short forms");

    var reg_s = cli_new();
    var av_s = _mk_argv("yo", "-c", "10", "-W", "500", "-s", "64", "8.8.8.8");
    assert_eq(cli_parse_argv(reg_s, 8, av_s), CLI_OK, "short forms parse");
    assert_eq(cli_count(reg_s),      10,    "-c 10");
    assert_eq(cli_timeout_ms(reg_s), 500,   "-W 500");
    assert_eq(cli_size(reg_s),       64,    "-s 64");
    assert_eq(streq(cli_target(reg_s), "8.8.8.8"), 1, "trailing target");

    # ----- CLI parse: long forms -----
    test_group("cli long forms");

    var reg_l = cli_new();
    var av_l = _mk_argv("yo", "--interval", "250", "--quiet", "--verbose", "router", 0, 0);
    assert_eq(cli_parse_argv(reg_l, 6, av_l), CLI_OK, "long forms parse");
    assert_eq(cli_interval_ms(reg_l), 250, "--interval 250");
    assert_eq(cli_quiet(reg_l),       1,   "--quiet set");
    assert_eq(cli_verbose(reg_l),     1,   "--verbose set");

    # ----- CLI parse: errors -----
    test_group("cli errors");

    var reg_m = cli_new();
    var av_m = _mk_argv("yo", 0, 0, 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_m, 1, av_m), CLI_ERR_MISSING_TARGET, "no positional → MISSING_TARGET");

    var reg_n = cli_new();
    var av_n = _mk_argv("yo", "-c", "-3", "host", 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_n, 4, av_n), CLI_ERR_NEGATIVE, "negative count rejected");

    var reg_h = cli_new();
    var av_h = _mk_argv("yo", "-h", 0, 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_h, 2, av_h), CLI_HELP, "-h returns CLI_HELP");

    var reg_u = cli_new();
    var av_u = _mk_argv("yo", "--nope", "host", 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_u, 3, av_u), CLI_ERR_PARSE, "unknown long flag → CLI_ERR_PARSE");

    # ----- ipv4_parse: happy paths -----
    test_group("ipv4_parse valid");

    assert_eq(ipv4_parse("0.0.0.0"),         0x00000000, "all zeros");
    assert_eq(ipv4_parse("127.0.0.1"),       0x7F000001, "loopback");
    assert_eq(ipv4_parse("192.168.1.1"),     0xC0A80101, "rfc1918 /16");
    assert_eq(ipv4_parse("255.255.255.255"), 0xFFFFFFFF, "broadcast / max");
    assert_eq(ipv4_parse("8.8.8.8"),         0x08080808, "single-digit segs");
    assert_eq(ipv4_parse("10.20.30.40"),     0x0A141E28, "two-digit segs");

    # ----- ipv4_parse: rejects -----
    test_group("ipv4_parse invalid");

    assert(ipv4_parse("")          < 0, "empty string rejected");
    assert(ipv4_parse("1.2.3")     < 0, "too few segments");
    assert(ipv4_parse("1.2.3.4.5") < 0, "too many segments");
    assert(ipv4_parse("256.0.0.0") < 0, "segment > 255");
    assert(ipv4_parse("999.0.0.0") < 0, "3-digit overflow caught mid-parse");
    assert(ipv4_parse("1.2.3.4 ")  < 0, "trailing space rejected");
    assert(ipv4_parse("1.2.3.")    < 0, "trailing dot rejected");
    assert(ipv4_parse(".1.2.3.4")  < 0, "leading dot rejected");
    assert(ipv4_parse("1..2.3")    < 0, "empty segment rejected");
    assert(ipv4_parse("abc")       < 0, "alpha-only rejected");
    assert(ipv4_parse("1.2.3.4a")  < 0, "trailing garbage rejected");
    assert(ipv4_parse("1234.5.6.7") < 0, "4-digit segment rejected");
    assert_eq(ipv4_parse(0), IPV4_PARSE_FAIL, "null ptr → FAIL sentinel");

    # ----- stats: empty + single sample -----
    test_group("stats basics");

    var s0 = stats_new();
    assert_eq(stats_sent(s0),     0, "fresh: sent=0");
    assert_eq(stats_recv(s0),     0, "fresh: recv=0");
    assert_eq(stats_loss_pct(s0), 0, "fresh: loss=0 (no division by zero)");
    assert_eq(stats_avg_us(s0),   0, "fresh: avg=0");
    assert_eq(stats_min_us(s0), STATS_MIN_UNSET, "fresh: min=UNSET sentinel");

    stats_record_reply(s0, 1000);
    assert_eq(stats_sent(s0),    1,    "one reply: sent=1");
    assert_eq(stats_recv(s0),    1,    "one reply: recv=1");
    assert_eq(stats_min_us(s0),  1000, "one reply: min=1000");
    assert_eq(stats_max_us(s0),  1000, "one reply: max=1000");
    assert_eq(stats_avg_us(s0),  1000, "one reply: avg=1000");

    # ----- stats: loss + mixed -----
    test_group("stats loss + mix");

    var s1 = stats_new();
    stats_record_reply(s1, 420);
    stats_record_loss(s1);
    assert_eq(stats_sent(s1),     2,   "mixed: sent=2");
    assert_eq(stats_recv(s1),     1,   "mixed: recv=1");
    assert_eq(stats_loss_pct(s1), 50,  "mixed: 50% loss");
    assert_eq(stats_min_us(s1),   420, "loss doesn't move min");

    # README example: three replies 390/410/420us.
    var s2 = stats_new();
    stats_record_reply(s2, 390);
    stats_record_reply(s2, 410);
    stats_record_reply(s2, 420);
    assert_eq(stats_sent(s2),     3,   "readme: sent=3");
    assert_eq(stats_recv(s2),     3,   "readme: recv=3");
    assert_eq(stats_loss_pct(s2), 0,   "readme: 0% loss");
    assert_eq(stats_min_us(s2),   390, "readme: min=390us");
    assert_eq(stats_max_us(s2),   420, "readme: max=420us");
    # avg = (390+410+420)/3 = 1220/3 = 406 (integer floor).
    assert_eq(stats_avg_us(s2), 406, "readme: avg=406us");

    # All-lost: loss=100, no min/max meaningful but accessors safe.
    var s3 = stats_new();
    stats_record_loss(s3);
    stats_record_loss(s3);
    assert_eq(stats_sent(s3),     2,   "all-lost: sent=2");
    assert_eq(stats_recv(s3),     0,   "all-lost: recv=0");
    assert_eq(stats_loss_pct(s3), 100, "all-lost: 100%");
    assert_eq(stats_avg_us(s3),   0,   "all-lost: avg=0 (no samples)");

    # ----- output: us → ms format -----
    test_group("output us→ms format");

    var fb[32];
    assert_eq(streq(_us_fmt(0,       &fb), "0.00"),    1, "0us → 0.00");
    assert_eq(streq(_us_fmt(5,       &fb), "0.01"),    1, "5us → 0.01 (round up)");
    assert_eq(streq(_us_fmt(390,     &fb), "0.39"),    1, "390us → 0.39");
    assert_eq(streq(_us_fmt(395,     &fb), "0.40"),    1, "395us → 0.40 (boundary round)");
    assert_eq(streq(_us_fmt(410,     &fb), "0.41"),    1, "410us → 0.41");
    assert_eq(streq(_us_fmt(1234,    &fb), "1.23"),    1, "1234us → 1.23");
    assert_eq(streq(_us_fmt(9995,    &fb), "10.00"),   1, "9995us → 10.00 (carry)");
    assert_eq(streq(_us_fmt(1500000, &fb), "1500.00"), 1, "1500000us → 1500.00");

    # ----- dns: qname encoder -----
    test_group("dns _encode_qname");

    var qn[32];
    var qnlen = _dns_encode_qname("google.com", &qn);
    assert_eq(qnlen, 12, "google.com → 12 bytes (6+google+3+com+0)");
    assert_eq(load8(&qn + 0),  6,    "label0 length = 6");
    assert_eq(load8(&qn + 1),  103,  "g = 0x67");
    assert_eq(load8(&qn + 7),  3,    "label1 length = 3");
    assert_eq(load8(&qn + 8),  99,   "c = 0x63");
    assert_eq(load8(&qn + 11), 0,    "terminator");

    # Trailing-dot accepted as canonical FQDN (same encoding as no-dot)
    var qn2[32];
    var qnlen2 = _dns_encode_qname("ex.io.", &qn2);
    assert_eq(qnlen2, 7, "ex.io. (trailing dot) → 7 bytes");
    assert_eq(load8(&qn2 + 0), 2, "first label len = 2");
    assert_eq(load8(&qn2 + 3), 2, "second label len = 2");
    assert_eq(load8(&qn2 + 6), 0, "terminator at off 6");

    var qn2b[32];
    var qnlen2b = _dns_encode_qname("ex.io", &qn2b);
    assert_eq(qnlen2, qnlen2b, "trailing dot encodes identically");

    # Rejects
    var qn3[32];
    assert(_dns_encode_qname("", &qn3)         < 0, "empty hostname rejected");
    assert(_dns_encode_qname("..foo", &qn3)    < 0, "leading dot rejected");
    assert(_dns_encode_qname("foo..bar", &qn3) < 0, "empty middle label rejected");
    assert(_dns_encode_qname(".foo", &qn3)     < 0, "single leading dot rejected");

    # ----- dns: build_query -----
    test_group("dns _build_query");

    var bq[64];
    var bqlen = _dns_build_query(&bq, 0xABCD, "ex.com");
    # Header(12) + qname("ex.com" = 2+ex+3+com+0 = 8) + qtype/class(4) = 24
    assert_eq(bqlen, 24, "build_query ex.com → 24 bytes");
    assert_eq(load8(&bq + 0),  0xAB, "id hi");
    assert_eq(load8(&bq + 1),  0xCD, "id lo");
    assert_eq(load8(&bq + 2),  0x01, "flags hi (RD=1)");
    assert_eq(load8(&bq + 3),  0x00, "flags lo (Z=0, RCODE=0)");
    assert_eq(load8(&bq + 5),  0x01, "QDCOUNT lo = 1");
    assert_eq(load8(&bq + 7),  0x00, "ANCOUNT lo = 0");
    # qname starts at off 12
    assert_eq(load8(&bq + 12), 2,    "first label length = 2");
    assert_eq(load8(&bq + 15), 3,    "second label length = 3");
    assert_eq(load8(&bq + 19), 0,    "qname terminator at off 19");
    # QTYPE/QCLASS at off 20-23
    assert_eq(load8(&bq + 21), 1, "QTYPE lo = 1 (A)");
    assert_eq(load8(&bq + 23), 1, "QCLASS lo = 1 (IN)");

    # ----- dns: skip_name -----
    test_group("dns _skip_name");

    # Uncompressed: 3 'f' 'o' 'o' 3 'b' 'a' 'r' 0 → ends at off 9
    var sn1[16];
    store8(&sn1 + 0, 3); store8(&sn1 + 1, 102); store8(&sn1 + 2, 111); store8(&sn1 + 3, 111);
    store8(&sn1 + 4, 3); store8(&sn1 + 5, 98);  store8(&sn1 + 6, 97);  store8(&sn1 + 7, 114);
    store8(&sn1 + 8, 0);
    assert_eq(_dns_skip_name(&sn1, 16, 0), 9, "uncompressed name ends past terminator");

    # Pointer: 3 'f' 'o' 'o' C0 0C → ends at off 6
    var sn2[16];
    store8(&sn2 + 0, 3); store8(&sn2 + 1, 102); store8(&sn2 + 2, 111); store8(&sn2 + 3, 111);
    store8(&sn2 + 4, 0xC0); store8(&sn2 + 5, 0x0C);
    assert_eq(_dns_skip_name(&sn2, 16, 0), 6, "label then pointer = 2-byte pointer");

    # Pointer-only at start
    var sn3[8];
    store8(&sn3 + 0, 0xC0); store8(&sn3 + 1, 0x0C);
    assert_eq(_dns_skip_name(&sn3, 8, 0), 2, "bare pointer = 2 bytes");

    # Malformed: oversized label length
    var sn4[8];
    store8(&sn4 + 0, 64);   # >63 and not a pointer
    assert(_dns_skip_name(&sn4, 8, 0) < 0, "oversized label rejected");

    # ----- dns: parse_response -----
    test_group("dns _parse_response");

    # Build a synthetic 41-byte response: ID=0xABCD, RCODE=0, 1 question
    # (foo.bar A IN), 1 answer (pointer-to-qname, A, IN, TTL=120, 127.0.0.1)
    var rsp[64];
    # Header
    store8(&rsp + 0,  0xAB); store8(&rsp + 1,  0xCD);    # ID
    store8(&rsp + 2,  0x81); store8(&rsp + 3,  0x80);    # QR=1 RD=1 RA=1 RCODE=0
    store8(&rsp + 4,  0);    store8(&rsp + 5,  1);       # QDCOUNT=1
    store8(&rsp + 6,  0);    store8(&rsp + 7,  1);       # ANCOUNT=1
    store8(&rsp + 8,  0);    store8(&rsp + 9,  0);       # NSCOUNT
    store8(&rsp + 10, 0);    store8(&rsp + 11, 0);       # ARCOUNT
    # Question: foo.bar A IN
    store8(&rsp + 12, 3); store8(&rsp + 13, 102); store8(&rsp + 14, 111); store8(&rsp + 15, 111);
    store8(&rsp + 16, 3); store8(&rsp + 17, 98);  store8(&rsp + 18, 97);  store8(&rsp + 19, 114);
    store8(&rsp + 20, 0);
    store8(&rsp + 21, 0); store8(&rsp + 22, 1);          # QTYPE A
    store8(&rsp + 23, 0); store8(&rsp + 24, 1);          # QCLASS IN
    # Answer: pointer to off 12, A IN, TTL=120, RDLEN=4, 127.0.0.1
    store8(&rsp + 25, 0xC0); store8(&rsp + 26, 0x0C);
    store8(&rsp + 27, 0); store8(&rsp + 28, 1);          # TYPE A
    store8(&rsp + 29, 0); store8(&rsp + 30, 1);          # CLASS IN
    store8(&rsp + 31, 0); store8(&rsp + 32, 0); store8(&rsp + 33, 0); store8(&rsp + 34, 120);
    store8(&rsp + 35, 0); store8(&rsp + 36, 4);          # RDLENGTH=4
    store8(&rsp + 37, 127); store8(&rsp + 38, 0); store8(&rsp + 39, 0); store8(&rsp + 40, 1);

    assert_eq(_dns_parse_response(&rsp, 41, 0xABCD), 0x7F000001, "A record → 127.0.0.1");

    # ID mismatch rejected
    assert(_dns_parse_response(&rsp, 41, 0x1234) < 0, "wrong qid rejected");

    # RCODE != 0 rejected (NXDOMAIN = 3)
    store8(&rsp + 3, 0x83);
    assert(_dns_parse_response(&rsp, 41, 0xABCD) < 0, "non-zero RCODE rejected");
    store8(&rsp + 3, 0x80);    # restore

    # QR bit clear (it's a query, not a response) → rejected
    store8(&rsp + 2, 0x01);
    assert(_dns_parse_response(&rsp, 41, 0xABCD) < 0, "QR=0 rejected");
    store8(&rsp + 2, 0x81);    # restore

    # Truncated response (header only) rejected
    assert(_dns_parse_response(&rsp, 8, 0xABCD) < 0, "len < header rejected");

    # ANCOUNT=0 rejected (no records to parse)
    store8(&rsp + 7, 0);
    assert(_dns_parse_response(&rsp, 41, 0xABCD) < 0, "ANCOUNT=0 rejected");
    store8(&rsp + 7, 1);       # restore

    # Multi-answer: CNAME first, A second. Tests the skip-non-A path.
    # Layout: header(12) + question(13) + CNAME ans(2+10+rdata) + A ans
    var rsp2[80];
    # Header
    store8(&rsp2 + 0,  0x12); store8(&rsp2 + 1,  0x34);    # ID
    store8(&rsp2 + 2,  0x81); store8(&rsp2 + 3,  0x80);    # flags
    store8(&rsp2 + 4,  0);    store8(&rsp2 + 5,  1);       # QDCOUNT=1
    store8(&rsp2 + 6,  0);    store8(&rsp2 + 7,  2);       # ANCOUNT=2
    store8(&rsp2 + 8,  0);    store8(&rsp2 + 9,  0);
    store8(&rsp2 + 10, 0);    store8(&rsp2 + 11, 0);
    # Question: a.b
    store8(&rsp2 + 12, 1); store8(&rsp2 + 13, 97);
    store8(&rsp2 + 14, 1); store8(&rsp2 + 15, 98);
    store8(&rsp2 + 16, 0);
    store8(&rsp2 + 17, 0); store8(&rsp2 + 18, 1);          # QTYPE A
    store8(&rsp2 + 19, 0); store8(&rsp2 + 20, 1);          # QCLASS IN
    # CNAME answer at off 21: ptr(2) + TYPE=5(2) + CLASS=1(2) + TTL(4) + RDLEN=4(2) + 4 bytes rdata
    store8(&rsp2 + 21, 0xC0); store8(&rsp2 + 22, 0x0C);
    store8(&rsp2 + 23, 0);    store8(&rsp2 + 24, 5);       # TYPE CNAME
    store8(&rsp2 + 25, 0);    store8(&rsp2 + 26, 1);       # CLASS IN
    store8(&rsp2 + 27, 0); store8(&rsp2 + 28, 0); store8(&rsp2 + 29, 0); store8(&rsp2 + 30, 60);
    store8(&rsp2 + 31, 0);    store8(&rsp2 + 32, 4);       # RDLEN 4 (4-byte rdata for compactness)
    store8(&rsp2 + 33, 1); store8(&rsp2 + 34, 1); store8(&rsp2 + 35, 1); store8(&rsp2 + 36, 1);
    # A answer at off 37
    store8(&rsp2 + 37, 0xC0); store8(&rsp2 + 38, 0x0C);
    store8(&rsp2 + 39, 0);    store8(&rsp2 + 40, 1);       # TYPE A
    store8(&rsp2 + 41, 0);    store8(&rsp2 + 42, 1);       # CLASS IN
    store8(&rsp2 + 43, 0); store8(&rsp2 + 44, 0); store8(&rsp2 + 45, 0); store8(&rsp2 + 46, 60);
    store8(&rsp2 + 47, 0);    store8(&rsp2 + 48, 4);       # RDLEN 4
    store8(&rsp2 + 49, 8); store8(&rsp2 + 50, 8); store8(&rsp2 + 51, 8); store8(&rsp2 + 52, 8);

    assert_eq(_dns_parse_response(&rsp2, 53, 0x1234), 0x08080808, "CNAME skipped, A returned");

    # ----- dns: resolv.conf parser -----
    test_group("dns _resolv_conf");

    # Single line, space separator
    var rc1 = "nameserver 8.8.8.8\n";
    assert_eq(_dns_resolv_conf_nameserver(rc1, strlen(rc1)), 0x08080808, "single nameserver line");

    # Tab separator + multiple lines (first wins)
    var rc2 = "nameserver\t1.1.1.1\nnameserver 9.9.9.9\n";
    assert_eq(_dns_resolv_conf_nameserver(rc2, strlen(rc2)), 0x01010101, "tab separator, first wins");

    # Comment + leading-ws skipped
    var rc3 = "# top comment\n  nameserver 8.8.4.4\n";
    assert_eq(_dns_resolv_conf_nameserver(rc3, strlen(rc3)), 0x08080404, "comment + indented line");

    # Other directives skipped
    var rc4 = "options ndots:1\nsearch lan\nnameserver 1.2.3.4\n";
    assert_eq(_dns_resolv_conf_nameserver(rc4, strlen(rc4)), 0x01020304, "skip non-nameserver directives");

    # Commented-out nameserver not picked
    var rc5 = "#nameserver 8.8.8.8\n";
    assert(_dns_resolv_conf_nameserver(rc5, strlen(rc5)) < 0, "commented nameserver ignored");

    # No file content
    var rc6 = "";
    assert(_dns_resolv_conf_nameserver(rc6, 0) < 0, "empty content → FAIL");

    # IPv6 nameserver skipped, IPv4 next line picked up
    var rc7 = "nameserver fe80::1\nnameserver 4.4.4.4\n";
    assert_eq(_dns_resolv_conf_nameserver(rc7, strlen(rc7)), 0x04040404, "IPv6 line skipped, IPv4 picked");

    # Missing trailing newline on last line still parses
    var rc8 = "nameserver 5.6.7.8";
    assert_eq(_dns_resolv_conf_nameserver(rc8, strlen(rc8)), 0x05060708, "no trailing newline ok");

    # ----- dns: reverse qname builder -----
    test_group("dns _build_reverse_qname");

    # 8.8.8.8 → 8.8.8.8.in-addr.arpa (22 bytes)
    var rq1[32];
    var rq1len = _dns_build_reverse_qname(0x08080808, &rq1);
    assert_eq(rq1len, 22, "8.8.8.8 → 22 bytes");
    assert_eq(load8(&rq1 + 0),  1,   "label0 len");
    assert_eq(load8(&rq1 + 1),  56,  "'8' = 0x38");
    assert_eq(load8(&rq1 + 8),  7,   "in-addr label len = 7");
    assert_eq(load8(&rq1 + 16), 4,   "arpa label len = 4");
    assert_eq(load8(&rq1 + 21), 0,   "terminator at off 21");

    # 142.250.190.46 → 46.190.250.142.in-addr.arpa (3-digit octets, 29 bytes)
    var rq2[40];
    var rq2len = _dns_build_reverse_qname(0x8EFABE2E, &rq2);
    assert_eq(rq2len, 29, "142.250.190.46 → 29 bytes (3-digit octets)");
    assert_eq(load8(&rq2 + 0), 2, "first octet label = len 2 ('46')");
    assert_eq(load8(&rq2 + 1), 52, "'4' = 0x34");
    assert_eq(load8(&rq2 + 2), 54, "'6' = 0x36");
    assert_eq(load8(&rq2 + 3), 3, "second octet label = len 3 ('190')");
    assert_eq(load8(&rq2 + 28), 0, "terminator at off 28");

    # 1.1.1.1 → labels all single-digit → 8 + 8 + 5 + 1 = 22 bytes
    var rq3[32];
    var rq3len = _dns_build_reverse_qname(0x01010101, &rq3);
    assert_eq(rq3len, 22, "1.1.1.1 → 22 bytes");

    # ----- dns: decode_name -----
    test_group("dns _decode_name");

    # Uncompressed "foo.bar" at off 0
    var dn1[16];
    store8(&dn1 + 0, 3); store8(&dn1 + 1, 102); store8(&dn1 + 2, 111); store8(&dn1 + 3, 111);
    store8(&dn1 + 4, 3); store8(&dn1 + 5, 98);  store8(&dn1 + 6, 97);  store8(&dn1 + 7, 114);
    store8(&dn1 + 8, 0);
    var out1[16];
    assert_eq(_dns_decode_name(&dn1, 16, 0, &out1, 16), 7, "decode foo.bar → 7 bytes");
    assert_eq(streq(&out1, "foo.bar"), 1, "decoded cstr matches");

    # Single pointer: "foo.bar" at off 0, pointer at off 9 jumps to 0
    var dn2[16];
    store8(&dn2 + 0, 3); store8(&dn2 + 1, 102); store8(&dn2 + 2, 111); store8(&dn2 + 3, 111);
    store8(&dn2 + 4, 3); store8(&dn2 + 5, 98);  store8(&dn2 + 6, 97);  store8(&dn2 + 7, 114);
    store8(&dn2 + 8, 0);
    store8(&dn2 + 9, 0xC0); store8(&dn2 + 10, 0x00);
    var out2[16];
    assert_eq(_dns_decode_name(&dn2, 16, 9, &out2, 16), 7, "decode via pointer → 7 bytes");
    assert_eq(streq(&out2, "foo.bar"), 1, "pointer decode same as direct");

    # Label + pointer: 1 'a' + ptr-to-foo.bar → "a.foo.bar"
    var dn3[24];
    store8(&dn3 + 0, 3); store8(&dn3 + 1, 102); store8(&dn3 + 2, 111); store8(&dn3 + 3, 111);
    store8(&dn3 + 4, 3); store8(&dn3 + 5, 98);  store8(&dn3 + 6, 97);  store8(&dn3 + 7, 114);
    store8(&dn3 + 8, 0);
    store8(&dn3 + 9, 1); store8(&dn3 + 10, 97);     # 'a'
    store8(&dn3 + 11, 0xC0); store8(&dn3 + 12, 0x00);
    var out3[16];
    assert_eq(_dns_decode_name(&dn3, 24, 9, &out3, 16), 9, "a + ptr-to-foo.bar → 9 bytes");
    assert_eq(streq(&out3, "a.foo.bar"), 1, "label-then-pointer decode");

    # Pointer-loop guard: pointer points to itself → FAIL after 16 jumps
    var dn4[8];
    store8(&dn4 + 0, 0xC0); store8(&dn4 + 1, 0x00);
    var out4[16];
    assert(_dns_decode_name(&dn4, 8, 0, &out4, 16) < 0, "self-loop pointer rejected");

    # Out-buf overflow: 5-byte cap, decoding "foo.bar" (needs 8 incl NUL) → FAIL
    var out5[5];
    assert(_dns_decode_name(&dn1, 16, 0, &out5, 5) < 0, "out-buf too small rejected");

    # Out-of-bounds pointer
    var dn6[4];
    store8(&dn6 + 0, 0xC0); store8(&dn6 + 1, 99);   # off 99 is way past len=4
    var out6[16];
    assert(_dns_decode_name(&dn6, 4, 0, &out6, 16) < 0, "pointer out of range rejected");

    # ----- dns: parse_ptr_response -----
    test_group("dns _parse_ptr_response");

    # Build a response: header + PTR question for 1.1.1.1 + answer with name "x.y"
    var pr[80];
    var pr_len = _dns_build_ptr_query(&pr, 0x1234, 0x01010101);   # 38 bytes (12 hdr + 22 qname + 4)
    # Flip to response: QR=1, RCODE=0, AN=1
    store8(&pr + 2, 0x81);
    store8(&pr + 3, 0x80);
    store8(&pr + 7, 1);
    # Answer at off 38: ptr(2) + type PTR(2) + class IN(2) + TTL(4) + rdlen(2) + rdata
    store8(&pr + 38, 0xC0); store8(&pr + 39, 0x0C);
    store8(&pr + 40, 0);    store8(&pr + 41, 12);   # TYPE PTR
    store8(&pr + 42, 0);    store8(&pr + 43, 1);    # CLASS IN
    store8(&pr + 44, 0); store8(&pr + 45, 0); store8(&pr + 46, 0); store8(&pr + 47, 120);
    store8(&pr + 48, 0);    store8(&pr + 49, 5);    # RDLEN 5
    store8(&pr + 50, 1);    store8(&pr + 51, 120);  # 'x'
    store8(&pr + 52, 1);    store8(&pr + 53, 121);  # 'y'
    store8(&pr + 54, 0);
    var pr_out[32];
    assert_eq(_dns_parse_ptr_response(&pr, 55, 0x1234, &pr_out, 32), 3, "PTR rdata decoded → 3 bytes");
    assert_eq(streq(&pr_out, "x.y"), 1, "PTR cstr matches");

    # ID mismatch
    assert(_dns_parse_ptr_response(&pr, 55, 0x9999, &pr_out, 32) < 0, "wrong qid rejected");

    # ----- output: ipv4_to_buf -----
    test_group("output ipv4_to_buf");

    var ib[20];
    assert_eq(output_ipv4_to_buf(0x7F000001, &ib), 9,  "127.0.0.1 → 9 bytes");
    assert_eq(streq(&ib, "127.0.0.1"), 1, "127.0.0.1 string");
    assert_eq(output_ipv4_to_buf(0xFFFFFFFF, &ib), 15, "255.255.255.255 → 15 bytes");
    assert_eq(streq(&ib, "255.255.255.255"), 1, "255.255.255.255 string");
    assert_eq(output_ipv4_to_buf(0x00000000, &ib), 7,  "0.0.0.0 → 7 bytes");
    assert_eq(streq(&ib, "0.0.0.0"), 1, "0.0.0.0 string");

    # ----- CLI: -n / --numeric -----
    test_group("cli numeric flag");

    var reg_nf = cli_new();
    var av_nf = _mk_argv("yo", "-n", "host", 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_nf, 3, av_nf), CLI_OK, "-n parses");
    assert_eq(cli_numeric(reg_nf), 1, "-n sets numeric");

    var reg_nl = cli_new();
    var av_nl = _mk_argv("yo", "--numeric", "host", 0, 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_nl, 3, av_nl), CLI_OK, "--numeric parses");
    assert_eq(cli_numeric(reg_nl), 1, "--numeric sets numeric");

    var reg_nd = cli_new();
    var av_nd = _mk_argv("yo", "host", 0, 0, 0, 0, 0, 0);
    cli_parse_argv(reg_nd, 2, av_nd);
    assert_eq(cli_numeric(reg_nd), 0, "numeric off by default");

    # ----- CLI: multiple targets -----
    test_group("cli multiple targets");

    var reg_m1 = cli_new();
    var av_m1 = _mk_argv("yo", "router", "8.8.8.8", "1.1.1.1", 0, 0, 0, 0);
    assert_eq(cli_parse_argv(reg_m1, 4, av_m1), CLI_OK, "three targets parse");
    assert_eq(cli_target_count(reg_m1), 3, "target_count = 3");
    assert_eq(streq(cli_target_at(reg_m1, 0), "router"),  1, "target[0] = router");
    assert_eq(streq(cli_target_at(reg_m1, 1), "8.8.8.8"), 1, "target[1] = 8.8.8.8");
    assert_eq(streq(cli_target_at(reg_m1, 2), "1.1.1.1"), 1, "target[2] = 1.1.1.1");
    assert_eq(streq(cli_target(reg_m1), "router"), 1, "cli_target == target_at(0)");

    # Flags interleaved with targets still collect targets in argv order
    var reg_m2 = cli_new();
    var av_m2 = _mk_argv("yo", "-c", "2", "a.host", "b.host", 0, 0, 0);
    assert_eq(cli_parse_argv(reg_m2, 5, av_m2), CLI_OK, "flag + two targets parse");
    assert_eq(cli_count(reg_m2), 2, "-c 2 applied");
    assert_eq(cli_target_count(reg_m2), 2, "two targets captured");
    assert_eq(streq(cli_target_at(reg_m2, 0), "a.host"), 1, "target[0] = a.host");
    assert_eq(streq(cli_target_at(reg_m2, 1), "b.host"), 1, "target[1] = b.host");

    # Single target still reports count=1
    var reg_m3 = cli_new();
    var av_m3 = _mk_argv("yo", "only.host", 0, 0, 0, 0, 0, 0);
    cli_parse_argv(reg_m3, 2, av_m3);
    assert_eq(cli_target_count(reg_m3), 1, "single target → count=1");

    # ----- ipv6_parse: happy paths -----
    test_group("ipv6_parse valid");

    var v6[16];

    # ::1 → 15 zero bytes then 0x01
    assert_eq(ipv6_parse("::1", &v6), 0, "::1 parses");
    var sum_zeros = 0; var k = 0;
    while (k < 15) { sum_zeros = sum_zeros + load8(&v6 + k); k = k + 1; }
    assert_eq(sum_zeros, 0, "::1 first 15 bytes are zero");
    assert_eq(load8(&v6 + 15), 1, "::1 last byte = 0x01");

    # :: → all zeros
    assert_eq(ipv6_parse("::", &v6), 0, ":: parses");
    var sum_all = 0; var k2 = 0;
    while (k2 < 16) { sum_all = sum_all + load8(&v6 + k2); k2 = k2 + 1; }
    assert_eq(sum_all, 0, ":: → 16 zero bytes");

    # 1:: → first byte 0x00, second 0x01, rest zero
    assert_eq(ipv6_parse("1::", &v6), 0, "1:: parses");
    assert_eq(load8(&v6 + 0), 0, "1:: byte 0 = 0x00");
    assert_eq(load8(&v6 + 1), 1, "1:: byte 1 = 0x01");
    assert_eq(load8(&v6 + 2), 0, "1:: byte 2 = 0x00");
    assert_eq(load8(&v6 + 15), 0, "1:: byte 15 = 0x00");

    # 2001:db8::1 → 20 01 0d b8 00..00 00 01
    assert_eq(ipv6_parse("2001:db8::1", &v6), 0, "2001:db8::1 parses");
    assert_eq(load8(&v6 + 0),  0x20, "byte 0 = 0x20");
    assert_eq(load8(&v6 + 1),  0x01, "byte 1 = 0x01");
    assert_eq(load8(&v6 + 2),  0x0D, "byte 2 = 0x0d");
    assert_eq(load8(&v6 + 3),  0xB8, "byte 3 = 0xb8");
    assert_eq(load8(&v6 + 4),  0x00, "byte 4 = 0x00");
    assert_eq(load8(&v6 + 14), 0x00, "byte 14 = 0x00");
    assert_eq(load8(&v6 + 15), 0x01, "byte 15 = 0x01");

    # Uppercase + mixed case
    assert_eq(ipv6_parse("2001:DB8::1", &v6), 0, "uppercase parses");
    assert_eq(load8(&v6 + 3), 0xB8, "uppercase byte 3 = 0xb8");
    assert_eq(ipv6_parse("2001:Db8::1", &v6), 0, "mixed case parses");
    assert_eq(load8(&v6 + 3), 0xB8, "mixed case byte 3 = 0xb8");

    # Full eight-group form (no zero compression)
    assert_eq(ipv6_parse("0001:0002:0003:0004:0005:0006:0007:0008", &v6), 0, "full 8-group");
    assert_eq(load8(&v6 + 0),  0x00, "g0 hi");
    assert_eq(load8(&v6 + 1),  0x01, "g0 lo");
    assert_eq(load8(&v6 + 14), 0x00, "g7 hi");
    assert_eq(load8(&v6 + 15), 0x08, "g7 lo");

    # Trailing "::" → trailing zero groups
    assert_eq(ipv6_parse("1:2:3::", &v6), 0, "1:2:3:: parses");
    assert_eq(load8(&v6 + 0), 0x00, "g0 hi");
    assert_eq(load8(&v6 + 1), 0x01, "g0 lo");
    assert_eq(load8(&v6 + 4), 0x00, "g2 hi");
    assert_eq(load8(&v6 + 5), 0x03, "g2 lo");
    assert_eq(load8(&v6 + 6),  0, "g3 zero");
    assert_eq(load8(&v6 + 15), 0, "tail zero");

    # Google DNS IPv6 — 2001:4860:4860::8888
    assert_eq(ipv6_parse("2001:4860:4860::8888", &v6), 0, "google v6 parses");
    assert_eq(load8(&v6 + 0),  0x20, "byte 0");
    assert_eq(load8(&v6 + 4),  0x48, "byte 4");
    assert_eq(load8(&v6 + 14), 0x88, "byte 14");
    assert_eq(load8(&v6 + 15), 0x88, "byte 15");

    # ----- ipv6_parse: rejects -----
    test_group("ipv6_parse invalid");

    assert(ipv6_parse("",                       &v6) < 0, "empty rejected");
    assert(ipv6_parse(":",                      &v6) < 0, "single colon rejected");
    assert(ipv6_parse(":1",                     &v6) < 0, "leading single colon rejected");
    assert(ipv6_parse("1:",                     &v6) < 0, "trailing single colon rejected");
    assert(ipv6_parse("1::2::3",                &v6) < 0, "double :: rejected");
    assert(ipv6_parse("12345::",                &v6) < 0, "5-digit group rejected");
    assert(ipv6_parse("1:2:3:4:5:6:7",          &v6) < 0, "7 groups w/o :: rejected");
    assert(ipv6_parse("1:2:3:4:5:6:7:8:9",      &v6) < 0, "9 groups rejected");
    assert(ipv6_parse("1:2:3:4:5:6:7:8::",      &v6) < 0, ":: with full 8 groups rejected (gap < 1)");
    assert(ipv6_parse("g::1",                   &v6) < 0, "non-hex digit rejected");
    assert(ipv6_parse("fe80::1%eth0",           &v6) < 0, "scope-id rejected (0.5.0 scope)");
    assert(ipv6_parse("::ffff:1.2.3.4",         &v6) < 0, "IPv4-embedded form rejected (0.5.1 scope)");
    assert_eq(ipv6_parse(0, &v6), IPV6_PARSE_FAIL, "null ptr → FAIL");

    # ----- cmsg TTL walk -----
    test_group("cmsg ttl walk");

    # Single IP_TTL cmsg: cmsg_len=20 (header 16 + i32 data 4), level=0,
    # type=2, data=58 → returns 58.
    var c1[32];
    store64(&c1 + 0,  20);              # cmsg_len
    store32(&c1 + 8,  _LX_IPPROTO_IP);  # level = 0
    store32(&c1 + 12, _LX_IP_TTL);      # type  = 2
    store32(&c1 + 16, 58);              # data  = 58
    assert_eq(_lx_cmsg_find_ttl(&c1, 24), 58, "single IP_TTL cmsg → 58");

    # Non-matching level (SOL_SOCKET=1, SO_TIMESTAMP=29 placeholder) →
    # 0. Avoids false positives when the kernel surfaces other cmsg.
    var c2[32];
    store64(&c2 + 0,  20);
    store32(&c2 + 8,  1);
    store32(&c2 + 12, 29);
    store32(&c2 + 16, 99);
    assert_eq(_lx_cmsg_find_ttl(&c2, 24), 0, "non-IP cmsg ignored");

    # Chain: non-matching cmsg first (24 B aligned), IP_TTL second.
    # Walker must skip past the first via CMSG_ALIGN(20)=24, then read.
    var c3[64];
    store64(&c3 + 0,  20);
    store32(&c3 + 8,  1);
    store32(&c3 + 12, 29);
    store32(&c3 + 16, 0);
    store64(&c3 + 24, 20);              # second cmsg starts at off 24
    store32(&c3 + 32, _LX_IPPROTO_IP);
    store32(&c3 + 36, _LX_IP_TTL);
    store32(&c3 + 40, 64);
    assert_eq(_lx_cmsg_find_ttl(&c3, 48), 64, "second-in-chain IP_TTL");

    # Truncated buffer (only 8 B of a 20 B cmsg) → 0. Walker must not
    # read past controllen.
    var c4[16];
    store64(&c4 + 0, 20);
    assert_eq(_lx_cmsg_find_ttl(&c4, 8), 0, "truncated cmsg → 0");

    # Malformed: cmsg_len below header size → reject, return 0.
    var c5[32];
    store64(&c5 + 0,  8);               # < 16 (header alone is 16)
    store32(&c5 + 8,  _LX_IPPROTO_IP);
    store32(&c5 + 12, _LX_IP_TTL);
    assert_eq(_lx_cmsg_find_ttl(&c5, 32), 0, "cmsg_len < 16 rejected");

    # Empty control buffer → 0.
    var c6[8];
    assert_eq(_lx_cmsg_find_ttl(&c6, 0), 0, "empty control → 0");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
