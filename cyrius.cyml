[package]
name = "yo"
version = "0.5.0"
description = "yo — Yodel-Out, ICMP echo probe (Cyrius-native sovereign ping)"
license = "GPL-3.0-only"
language = "cyrius"
cyrius = "6.0.1"

[build]
entry = "src/main.cyr"
test = "src/test.cyr"
output = "yo"

[deps]
stdlib = ["string", "fmt", "alloc", "io", "vec", "str", "syscalls", "assert", "bench", "args", "flags"]
---
